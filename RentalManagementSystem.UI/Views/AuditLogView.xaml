<UserControl x:Class="RentalManagementSystem.UI.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:loc="clr-namespace:RentalManagementSystem.UI.Localization">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="{loc:Tr S017}" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="{loc:Tr S018}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,0" />
            </StackPanel>
            <Button HorizontalAlignment="Right" Command="{Binding RefreshCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Padding="16,8">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" VerticalAlignment="Center" />
                    <TextBlock Text="{loc:Tr S019}" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid Style="{StaticResource ModernDataGridStyle}" ItemsSource="{Binding Logs}"
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:Tr S020}" Binding="{Binding Timestamp, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="160" />
                    <DataGridTextColumn Header="{loc:Tr S021}" Binding="{Binding UserName}" Width="130" />
                    <DataGridTextColumn Header="{loc:Tr S022}" Binding="{Binding Action}" Width="180" />
                    <DataGridTextColumn Header="{loc:Tr S023}" Binding="{Binding EntityType}" Width="110" />
                    <DataGridTextColumn Header="{loc:Tr S024}" Binding="{Binding EntityRef}" Width="120" />
                    <DataGridTextColumn Header="{loc:Tr S025}" Binding="{Binding Details}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
