<UserControl x:Class="RentalManagementSystem.UI.Views.ContractView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:loc="clr-namespace:RentalManagementSystem.UI.Localization">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{loc:Tr S026}" Style="{StaticResource PageTitleStyle}" VerticalAlignment="Center" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Command="{Binding OpenAddDialogCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="13,9" FontSize="13">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="Plus" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="{loc:Tr S027}" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
                <Button Command="{Binding OpenEditDialogCommand}" CommandParameter="{Binding SelectedContract}" IsEnabled="{Binding SelectedContract, Converter={StaticResource NotNullToBoolConverter}}" Style="{StaticResource SecondaryButtonStyle}" Padding="13,9" FontSize="13" Margin="6,0,0,0" ToolTip="{loc:Tr S028}">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="Pencil" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="{loc:Tr S003}" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
                <Button Command="{Binding OpenRenewDialogCommand}" CommandParameter="{Binding SelectedContract}" IsEnabled="{Binding SelectedContract, Converter={StaticResource NotNullToBoolConverter}}" Style="{StaticResource SuccessButtonStyle}" Padding="13,9" FontSize="13" Margin="6,0,0,0" ToolTip="{loc:Tr S029}">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="Refresh" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="{loc:Tr S029}" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
                <Button Command="{Binding OpenSubscriptionDialogCommand}" CommandParameter="{Binding SelectedContract}" IsEnabled="{Binding SelectedContract, Converter={StaticResource NotNullToBoolConverter}}" Style="{StaticResource SecondaryButtonStyle}" Padding="13,9" FontSize="13" Margin="6,0,0,0" ToolTip="{loc:Tr S030}">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="Cog" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="{loc:Tr S031}" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
                <Button Command="{Binding OpenTransferDialogCommand}" CommandParameter="{Binding SelectedContract}" IsEnabled="{Binding SelectedContract, Converter={StaticResource NotNullToBoolConverter}}" Style="{StaticResource SecondaryButtonStyle}" Padding="13,9" FontSize="13" Margin="6,0,0,0" ToolTip="{loc:Tr S032}">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="AccountSwitch" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="{loc:Tr S033}" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
                <Button Command="{Binding OpenCheckoutDialogCommand}" CommandParameter="{Binding SelectedContract}" IsEnabled="{Binding SelectedContract, Converter={StaticResource NotNullToBoolConverter}}" Style="{StaticResource DangerButtonStyle}" Padding="13,9" FontSize="13" Margin="6,0,0,0" ToolTip="{loc:Tr S034}">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="LogoutVariant" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="{loc:Tr S035}" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <DataGrid Style="{StaticResource ModernDataGridStyle}" ItemsSource="{Binding Contracts}" SelectedItem="{Binding SelectedContract}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:Tr S036}" Binding="{Binding ContractNo}" Width="120" />
                    <DataGridTextColumn Header="{loc:Tr S037}" Binding="{Binding Tenant.FullName}" Width="*" />
                    <DataGridTextColumn Header="{loc:Tr S038}" Binding="{Binding Room.RoomCode}" Width="90" />
                    <DataGridTextColumn Header="{loc:Tr S039}" Binding="{Binding StartDate, StringFormat=dd/MM/yyyy}" Width="120" />
                    <DataGridTextColumn Header="{loc:Tr S040}" Binding="{Binding EndDate, StringFormat=dd/MM/yyyy}" Width="120" />
                    <DataGridTextColumn Header="{loc:Tr S041}" Binding="{Binding MonthlyRent, StringFormat={}{0:N0} ₫}" Width="130" />
                    <DataGridTextColumn Header="{loc:Tr S042}" Binding="{Binding DepositAmount, StringFormat={}{0:N0} ₫}" Width="130" />
                    <DataGridTemplateColumn Header="{loc:Tr S043}" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="8,3" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Active">
                                                    <Setter Property="Background" Value="#E8F5E9" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Expired">
                                                    <Setter Property="Background" Value="#FFF8E1" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Terminated">
                                                    <Setter Property="Background" Value="#FFEBEE" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="Medium">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Active">
                                                        <Setter Property="Text" Value="Hiệu lực" />
                                                        <Setter Property="Foreground" Value="#2E7D32" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Expired">
                                                        <Setter Property="Text" Value="Hết hạn" />
                                                        <Setter Property="Foreground" Value="#E65100" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Terminated">
                                                        <Setter Property="Text" Value="Thanh lý" />
                                                        <Setter Property="Foreground" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Add/Edit Dialog -->
        <Grid Grid.RowSpan="2" Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#80000000" />
            <Border MaxWidth="560" MaxHeight="680" VerticalAlignment="Center" HorizontalAlignment="Center"
                   Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr S044}" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,20" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S045}" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding FormContractNo}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" IsReadOnly="True" Background="#F5F5F5" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S046}" Style="{StaticResource FormLabelStyle}" />
                                <ComboBox ItemsSource="{Binding Tenants}" SelectedValuePath="Id" SelectedValue="{Binding FormTenantId}" DisplayMemberPath="FullName" Height="40" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S047}" Style="{StaticResource FormLabelStyle}" />
                                <ComboBox ItemsSource="{Binding Rooms}" SelectedValuePath="Id" SelectedValue="{Binding FormRoomId}" DisplayMemberPath="RoomCode" Height="40" />
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S039}" Style="{StaticResource FormLabelStyle}" />
                                <DatePicker SelectedDate="{Binding FormStartDate}" Height="40" />
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S040}" Style="{StaticResource FormLabelStyle}" />
                                <DatePicker SelectedDate="{Binding FormEndDate}" Height="40" />
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S048}" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding FormMonthlyRent, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S049}" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding FormDepositAmount, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S050}" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding FormPaymentDueDay}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Row="5" Grid.Column="2" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S051}" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding FormOccupantCount}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                                  Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" Margin="0,8,0,0" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Content="{loc:Tr S015}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseDialogCommand}" Padding="24,10" />
                            <Button Content="{loc:Tr S016}" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}" Padding="24,10" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Renew Dialog -->
        <Grid Grid.RowSpan="2" Visibility="{Binding IsRenewDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#80000000" />
            <Border MaxWidth="380" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{loc:Tr S052}" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,20" />
                    <TextBlock Text="{loc:Tr S053}" Style="{StaticResource FormLabelStyle}" />
                    <DatePicker SelectedDate="{Binding RenewEndDate}" Height="40" Margin="0,0,0,20" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{loc:Tr S015}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseDialogCommand}" Padding="24,10" />
                        <Button Content="{loc:Tr S029}" Style="{StaticResource SuccessButtonStyle}" Command="{Binding RenewCommand}" Padding="24,10" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Subscription (Dịch vụ theo hợp đồng) Dialog -->
        <Grid Grid.RowSpan="2" Visibility="{Binding IsSubscriptionDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#80000000" />
            <Border MaxWidth="640" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{loc:Tr S054}" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding SubscriptionContract.ContractNo, StringFormat=Hợp đồng: {0}}" Foreground="#757575" FontSize="12" Margin="0,0,0,16" />

                    <!-- Form thêm dịch vụ -->
                    <Border Background="#F5F7FA" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" /><ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Tr S031}" Style="{StaticResource FormLabelStyle}" />
                            <ComboBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding AvailableServices}" SelectedValuePath="Id"
                                      SelectedValue="{Binding SubServiceId}" DisplayMemberPath="ServiceName" Height="38" />

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{loc:Tr S055}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding SubQuantity}" Height="38" Padding="8,0" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />

                            <TextBlock Grid.Row="0" Grid.Column="4" Text="{loc:Tr S056}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding SubUnitPrice}" Height="38" Padding="8,0" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />

                            <CheckBox Grid.Row="1" Grid.Column="6" Content="{loc:Tr S057}" IsChecked="{Binding SubIsPerPerson}" VerticalAlignment="Center" />

                            <Button Grid.Row="1" Grid.Column="8" Content="{loc:Tr S002}" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding AddSubscriptionCommand}" Padding="18,8" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Danh sách dịch vụ đã đăng ký -->
                    <DataGrid Style="{StaticResource ModernDataGridStyle}" ItemsSource="{Binding Subscriptions}" MaxHeight="240">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{loc:Tr S031}" Binding="{Binding Service.ServiceName}" Width="*" />
                            <DataGridTextColumn Header="{loc:Tr S055}" Binding="{Binding Quantity, StringFormat={}{0:N0}}" Width="90" />
                            <DataGridTextColumn Header="{loc:Tr S058}" Binding="{Binding UnitPrice, StringFormat={}{0:N0} ₫}" Width="110" />
                            <DataGridCheckBoxColumn Header="{loc:Tr S057}" Binding="{Binding IsPerPerson}" Width="90" />
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource DangerButtonStyle}" Padding="8,6"
                                                Command="{Binding DataContext.RemoveSubscriptionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <iconPacks:PackIconMaterial Kind="Delete" Width="13" Height="13" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="{loc:Tr S059}" Foreground="#9E9E9E" FontSize="11" Margin="0,8,0,0" />
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                              Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" Margin="0,4,0,0" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="{loc:Tr S060}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseSubscriptionDialogCommand}" Padding="24,10" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Dialog Trả phòng -->
        <Grid Grid.RowSpan="2" Visibility="{Binding IsCheckoutDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#80000000" />
            <Border MaxWidth="440" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{loc:Tr S061}" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding CheckoutContract.ContractNo, StringFormat=Hợp đồng: {0}}" Foreground="#757575" FontSize="12" Margin="0,0,0,16" />

                    <Border Background="#FFF8E1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="{loc:Tr S062}" Foreground="#757575" />
                                <TextBlock Text="{Binding CheckoutOutstanding, StringFormat={}{0:N0} ₫}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="#C62828" />
                            </Grid>
                            <Grid>
                                <TextBlock Text="{loc:Tr S063}" Foreground="#757575" />
                                <TextBlock Text="{Binding CheckoutContract.DepositAmount, StringFormat={}{0:N0} ₫}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="#7A1E3A" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{loc:Tr S064}" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding CheckoutDeduction, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" Margin="0,0,0,12" />

                    <Border Background="#E8F5E9" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                        <Grid>
                            <TextBlock Text="{loc:Tr S065}" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CheckoutRefund, StringFormat={}{0:N0} ₫}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="16" Foreground="#2E7D32" />
                        </Grid>
                    </Border>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                              Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" Margin="0,4,0,0" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="{loc:Tr S015}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseCheckoutDialogCommand}" Padding="24,10" />
                        <Button Content="{loc:Tr S066}" Style="{StaticResource DangerButtonStyle}" Command="{Binding ConfirmCheckoutCommand}" Padding="24,10" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Dialog Nhường phòng -->
        <Grid Grid.RowSpan="2" Visibility="{Binding IsTransferDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#80000000" />
            <Border MaxWidth="440" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{loc:Tr S032}" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding TransferContract.ContractNo, StringFormat=HĐ hiện tại: {0}}" Foreground="#757575" FontSize="12" Margin="0,0,0,16" />

                    <TextBlock Text="{loc:Tr S067}" Style="{StaticResource FormLabelStyle}" />
                    <ComboBox ItemsSource="{Binding Tenants}" SelectedValuePath="Id" SelectedValue="{Binding TransferNewTenantId}" DisplayMemberPath="FullName" Height="40" Margin="0,0,0,14" />

                    <CheckBox Content="{loc:Tr S068}" IsChecked="{Binding TransferKeepDeposit}" Margin="0,0,0,12" />

                    <TextBlock Text="{loc:Tr S069}" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding TransferNewDeposit, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" Margin="0,0,0,8" />

                    <TextBlock Text="{loc:Tr S070}" Foreground="#9E9E9E" FontSize="11" />
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                              Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" Margin="0,4,0,0" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="{loc:Tr S015}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseTransferDialogCommand}" Padding="24,10" />
                        <Button Content="{loc:Tr S071}" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ConfirmTransferCommand}" Padding="24,10" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

