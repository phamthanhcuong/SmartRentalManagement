<UserControl x:Class="RentalManagementSystem.UI.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <UserControl.Resources>
        <!-- Ô lớn 1 chạm -->
        <Style x:Key="HomeTile" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="16" Background="White" Padding="22" Margin="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.10" Color="#000000" />
                            </Border.Effect>
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#7A1E3A" />
                                <Setter Property="TextElement.Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Bước quy trình -->
        <Style x:Key="StepTile" TargetType="Button" BasedOn="{StaticResource HomeTile}" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Lời chào lớn -->
            <TextBlock Text="{Binding Greeting}" FontSize="30" FontWeight="Bold" Foreground="#4E0F25" />
            <TextBlock Text="{Binding Today}" FontSize="17" Foreground="#5A5A5A" Margin="0,4,0,0" />

            <!-- Quy trình hàng tháng -->
            <TextBlock Text="Việc làm hàng tháng — làm lần lượt 1 → 2 → 3" FontSize="18" FontWeight="SemiBold"
                       Foreground="#4E0F25" Margin="10,28,0,4" />
            <UniformGrid Rows="1" Columns="3">
                <Button Style="{StaticResource StepTile}" Command="{Binding GoCommand}" CommandParameter="DienNuoc">
                    <StackPanel>
                        <Border Width="56" Height="56" CornerRadius="28" Background="#F7E9EE" HorizontalAlignment="Left">
                            <TextBlock Text="1" FontSize="26" FontWeight="Bold" Foreground="#7A1E3A"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Nhập điện nước" FontSize="20" FontWeight="Bold" Margin="0,14,0,2" />
                        <TextBlock Text="Ghi số điện, số nước các phòng" FontSize="14" Foreground="#6A6A6A" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource StepTile}" Command="{Binding GoCommand}" CommandParameter="HoaDon">
                    <StackPanel>
                        <Border Width="56" Height="56" CornerRadius="28" Background="#F7E9EE" HorizontalAlignment="Left">
                            <TextBlock Text="2" FontSize="26" FontWeight="Bold" Foreground="#7A1E3A"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Tạo hóa đơn" FontSize="20" FontWeight="Bold" Margin="0,14,0,2" />
                        <TextBlock Text="Tính tiền tháng này cho các phòng" FontSize="14" Foreground="#6A6A6A" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource StepTile}" Command="{Binding GoCommand}" CommandParameter="HoaDon">
                    <StackPanel>
                        <Border Width="56" Height="56" CornerRadius="28" Background="#F7E9EE" HorizontalAlignment="Left">
                            <TextBlock Text="3" FontSize="26" FontWeight="Bold" Foreground="#7A1E3A"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Thu tiền &amp; In" FontSize="20" FontWeight="Bold" Margin="0,14,0,2" />
                        <TextBlock Text="Nhận tiền và in hóa đơn cho khách" FontSize="14" Foreground="#6A6A6A" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
            </UniformGrid>

            <!-- Các việc khác -->
            <TextBlock Text="Các mục khác" FontSize="18" FontWeight="SemiBold" Foreground="#4E0F25" Margin="10,24,0,4" />
            <UniformGrid Rows="2" Columns="3">
                <Button Style="{StaticResource HomeTile}" Command="{Binding GoCommand}" CommandParameter="Phong">
                    <StackPanel>
                        <iconPacks:PackIconMaterial Kind="DoorOpen" Width="40" Height="40" Foreground="#7A1E3A" />
                        <TextBlock Text="Phòng trọ" FontSize="19" FontWeight="Bold" Margin="0,12,0,2" />
                        <TextBlock Text="Xem và quản lý các phòng" FontSize="14" Foreground="#6A6A6A" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HomeTile}" Command="{Binding GoCommand}" CommandParameter="KhachThue">
                    <StackPanel>
                        <iconPacks:PackIconMaterial Kind="AccountGroup" Width="40" Height="40" Foreground="#7A1E3A" />
                        <TextBlock Text="Khách thuê" FontSize="19" FontWeight="Bold" Margin="0,12,0,2" />
                        <TextBlock Text="Thông tin người thuê &amp; xe" FontSize="14" Foreground="#6A6A6A" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HomeTile}" Command="{Binding GoCommand}" CommandParameter="HopDong">
                    <StackPanel>
                        <iconPacks:PackIconMaterial Kind="FileDocument" Width="40" Height="40" Foreground="#7A1E3A" />
                        <TextBlock Text="Hợp đồng" FontSize="19" FontWeight="Bold" Margin="0,12,0,2" />
                        <TextBlock Text="Tạo, gia hạn, trả phòng" FontSize="14" Foreground="#6A6A6A" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HomeTile}" Command="{Binding GoCommand}" CommandParameter="TraCuuXe">
                    <StackPanel>
                        <iconPacks:PackIconMaterial Kind="Motorbike" Width="40" Height="40" Foreground="#7A1E3A" />
                        <TextBlock Text="Tra cứu xe" FontSize="19" FontWeight="Bold" Margin="0,12,0,2" />
                        <TextBlock Text="Tìm xe theo biển số" FontSize="14" Foreground="#6A6A6A" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HomeTile}" Command="{Binding GoCommand}" CommandParameter="ThuChi">
                    <StackPanel>
                        <iconPacks:PackIconMaterial Kind="CurrencyUsd" Width="40" Height="40" Foreground="#7A1E3A" />
                        <TextBlock Text="Thu chi" FontSize="19" FontWeight="Bold" Margin="0,12,0,2" />
                        <TextBlock Text="Sổ tiền vào - ra" FontSize="14" Foreground="#6A6A6A" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HomeTile}" Command="{Binding GoCommand}" CommandParameter="BaoCao">
                    <StackPanel>
                        <iconPacks:PackIconMaterial Kind="ChartBar" Width="40" Height="40" Foreground="#7A1E3A" />
                        <TextBlock Text="Báo cáo" FontSize="19" FontWeight="Bold" Margin="0,12,0,2" />
                        <TextBlock Text="Doanh thu, công nợ" FontSize="14" Foreground="#6A6A6A" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
