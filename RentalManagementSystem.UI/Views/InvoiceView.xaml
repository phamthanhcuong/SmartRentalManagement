<UserControl x:Class="RentalManagementSystem.UI.Views.InvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:loc="clr-namespace:RentalManagementSystem.UI.Localization">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{loc:Tr S130}" Style="{StaticResource PageTitleStyle}" />
            <Button HorizontalAlignment="Right" Command="{Binding GenerateMonthlyCommand}"
                   Style="{StaticResource SuccessButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="AutoFix" Width="16" Height="16" VerticalAlignment="Center" />
                    <TextBlock Text="{loc:Tr S131}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Filter + Thao tác trên hóa đơn đang chọn -->
        <DockPanel Grid.Row="1" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Command="{Binding OpenPayDialogCommand}" CommandParameter="{Binding SelectedInvoice}" IsEnabled="{Binding SelectedInvoice, Converter={StaticResource NotNullToBoolConverter}}" Style="{StaticResource SuccessButtonStyle}" Padding="14,9" FontSize="14" ToolTip="{loc:Tr S132}">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="CurrencyUsd" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="{loc:Tr S125}" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
                <Button Command="{Binding PrintCommand}" CommandParameter="{Binding SelectedInvoice}" IsEnabled="{Binding SelectedInvoice, Converter={StaticResource NotNullToBoolConverter}}" Style="{StaticResource SecondaryButtonStyle}" Padding="14,9" FontSize="14" Margin="8,0,0,0" ToolTip="{loc:Tr S133}">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="Printer" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="In" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
                <Button Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedInvoice}" IsEnabled="{Binding SelectedInvoice, Converter={StaticResource NotNullToBoolConverter}}" Style="{StaticResource DangerButtonStyle}" Padding="14,9" FontSize="14" Margin="8,0,0,0" ToolTip="{loc:Tr S134}">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="Delete" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="{loc:Tr S004}" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{loc:Tr S113}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBox Text="{Binding FilterMonth}" Width="60" Height="36" Padding="8,0" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                <TextBlock Text="{loc:Tr S114}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBox Text="{Binding FilterYear}" Width="80" Height="36" Padding="8,0" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                <Button Content="{loc:Tr S115}" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding FilterCommand}" Padding="20,8" />
            </StackPanel>
        </DockPanel>

        <!-- Success Message -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <DataGrid Style="{StaticResource ModernDataGridStyle}" ItemsSource="{Binding Invoices}" SelectedItem="{Binding SelectedInvoice}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{loc:Tr S036}" Binding="{Binding InvoiceNo}" Width="120" />
                        <DataGridTextColumn Header="{loc:Tr S038}" Binding="{Binding Room.RoomCode}" Width="80" />
                        <DataGridTextColumn Header="{loc:Tr S104}" Binding="{Binding Tenant.FullName}" Width="*" />
                        <DataGridTextColumn Header="{loc:Tr S135}" Width="80">
                            <DataGridTextColumn.Binding>
                                <MultiBinding StringFormat="{}{0:D2}/{1}">
                                    <Binding Path="Month" />
                                    <Binding Path="Year" />
                                </MultiBinding>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="{loc:Tr S041}" Binding="{Binding RentAmount, StringFormat={}{0:N0} ₫}" Width="110" />
                        <DataGridTextColumn Header="{loc:Tr S136}" Width="110">
                            <DataGridTextColumn.Binding>
                                <MultiBinding StringFormat="{}{0:N0} ₫">
                                    <Binding Path="ElectricAmount" />
                                </MultiBinding>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="{loc:Tr S137}" Binding="{Binding PreviousDebt, StringFormat={}{0:N0} ₫}" Width="110" />
                        <DataGridTextColumn Header="{loc:Tr S138}" Binding="{Binding TotalAmount, StringFormat={}{0:N0} ₫}" Width="120" />
                        <DataGridTextColumn Header="{loc:Tr S139}" Binding="{Binding PaidAmount, StringFormat={}{0:N0} ₫}" Width="110" />
                        <DataGridTemplateColumn Header="{loc:Tr S043}" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="8,3" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Paid"><Setter Property="Background" Value="#E8F5E9" /></DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Unpaid"><Setter Property="Background" Value="#FFF8E1" /></DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="PartiallyPaid"><Setter Property="Background" Value="#F7E9EE" /></DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Overdue"><Setter Property="Background" Value="#FFEBEE" /></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="Medium">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paid"><Setter Property="Text" Value="✓ Đã thu" /><Setter Property="Foreground" Value="#2E7D32" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Unpaid"><Setter Property="Text" Value="Chưa thu" /><Setter Property="Foreground" Value="#E65100" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="PartiallyPaid"><Setter Property="Text" Value="Trả một phần" /><Setter Property="Foreground" Value="#7A1E3A" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Overdue"><Setter Property="Text" Value="Quá hạn" /><Setter Property="Foreground" Value="#C62828" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Pay Dialog -->
        <Grid Grid.RowSpan="3" Visibility="{Binding IsPayDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#80000000" />
            <Border MaxWidth="400" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{loc:Tr S140}" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,20" />
                    <Border Background="#E8F5E9" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{loc:Tr S141}" Foreground="#757575" FontSize="12" />
                            <TextBlock Text="{Binding SelectedInvoice.TotalAmount, StringFormat={}{0:N0} ₫}"
                                      FontSize="24" FontWeight="Bold" Foreground="#2E7D32" />
                            <TextBlock Text="{Binding SelectedInvoice.PaidAmount, StringFormat=Đã thu: {0:N0} ₫}"
                                      FontSize="12" Foreground="#757575" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{loc:Tr S142}" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding PayAmount, UpdateSourceTrigger=PropertyChanged}"
                            Height="48" FontSize="18" Padding="12,0" BorderThickness="1"
                            BorderBrush="{StaticResource DividerBrush}" Margin="0,0,0,20"
                            VerticalContentAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{loc:Tr S015}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseDialogCommand}" Padding="24,10" />
                        <Button Content="{loc:Tr S143}" Style="{StaticResource SuccessButtonStyle}" Command="{Binding PayCommand}" Padding="24,10" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

