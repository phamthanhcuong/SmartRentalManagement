<Window x:Class="RentalManagementSystem.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:loc="clr-namespace:RentalManagementSystem.UI.Localization"
        Title="Đăng Nhập - Quản Lý Nhà Trọ"
        Width="900" Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Effect>
        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" />
    </Window.Effect>

    <Border CornerRadius="16" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Branding -->
            <Border Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4E0F25" Offset="0" />
                        <GradientStop Color="#7A1E3A" Offset="0.5" />
                        <GradientStop Color="#9E2A4D" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                    <!-- Logo Icon -->
                    <Border Width="100" Height="100" CornerRadius="50" Margin="0,0,0,24"
                            HorizontalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="#FFFFFF" Opacity="0.15" />
                        </Border.Background>
                        <iconPacks:PackIconMaterial Kind="HomeCity" Width="56" Height="56"
                                                   Foreground="White" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="{loc:Tr Login.BrandTitle}" FontSize="28" FontWeight="Bold"
                              Foreground="White" HorizontalAlignment="Center" />
                    <TextBlock Text="{loc:Tr Login.BrandSubtitle}" FontSize="14"
                              Foreground="#E8B9C6" HorizontalAlignment="Center"
                              Margin="0,8,0,40" />

                    <!-- Features -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CheckCircle" Width="20" Height="20" Foreground="#4CAF50" />
                            <TextBlock Text="Quản lý phòng trọ toàn diện" Foreground="#C9A9B3" FontSize="13" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CheckCircle" Width="20" Height="20" Foreground="#4CAF50" />
                            <TextBlock Text="Hóa đơn điện nước tự động" Foreground="#C9A9B3" FontSize="13" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CheckCircle" Width="20" Height="20" Foreground="#4CAF50" />
                            <TextBlock Text="Báo cáo doanh thu chi tiết" Foreground="#C9A9B3" FontSize="13" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CheckCircle" Width="20" Height="20" Foreground="#4CAF50" />
                            <TextBlock Text="Xuất Excel &amp; PDF" Foreground="#C9A9B3" FontSize="13" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Right Panel - Login Form -->
            <Border Grid.Column="1" Background="White">
                <Grid>
                    <!-- Close Button -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,12,0"
                           Width="32" Height="32" Click="CloseButton_Click"
                           Style="{StaticResource PrimaryButtonStyle}"
                           ToolTip="Đóng">
                        <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14" />
                    </Button>

                    <StackPanel VerticalAlignment="Center" Margin="48,0">
                        <TextBlock Text="{loc:Tr Login.Title}" FontSize="30" FontWeight="Bold"
                                  Foreground="#3A0E1E" Margin="0,0,0,4" />
                        <TextBlock Text="{loc:Tr Login.Subtitle}" FontSize="14"
                                  Foreground="#757575" Margin="0,0,0,40" />

                        <!-- Error Message -->
                        <Border Background="#FFEBEE" CornerRadius="8" Padding="12,10"
                               Margin="0,0,0,16"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="AlertCircle" Width="16" Height="16"
                                                           Foreground="#F44336" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#D32F2F" FontSize="13"
                                          TextWrapping="Wrap" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Username -->
                        <TextBlock Text="{loc:Tr Login.Username}" Style="{StaticResource FormLabelStyle}" />
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                               Margin="0,0,0,20" Height="48">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="#E0E0E0">
                                    <iconPacks:PackIconMaterial Kind="Account" Width="20" Height="20"
                                                               Foreground="#9E9E9E"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBox Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                        BorderThickness="0" Padding="12,0"
                                        VerticalContentAlignment="Center"
                                        FontSize="14" Background="Transparent"
                                        materialDesign:HintAssist.Hint="{loc:Tr Login.UsernameHint}" />
                            </Grid>
                        </Border>

                        <!-- Password -->
                        <TextBlock Text="{loc:Tr Login.Password}" Style="{StaticResource FormLabelStyle}" />
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                               Margin="0,0,0,12" Height="48">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="48" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="#E0E0E0">
                                    <iconPacks:PackIconMaterial Kind="Lock" Width="20" Height="20"
                                                               Foreground="#9E9E9E"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                </Border>
                                <PasswordBox x:Name="PasswordBox" Grid.Column="1"
                                            BorderThickness="0" Padding="12,0"
                                            VerticalContentAlignment="Center"
                                            FontSize="14" Background="Transparent"
                                            Visibility="{Binding ShowPassword, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                            PasswordChanged="PasswordBox_PasswordChanged" />
                                <TextBox x:Name="PasswordTextBox" Grid.Column="1"
                                            BorderThickness="0" Padding="12,0"
                                            VerticalContentAlignment="Center"
                                            FontSize="14" Background="Transparent"
                                            Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                            Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Button Grid.Column="2" Command="{Binding TogglePasswordCommand}"
                                       BorderThickness="0" Background="Transparent" ToolTip="Hiện/ẩn mật khẩu">
                                    <iconPacks:PackIconMaterial Width="18" Height="18" Foreground="#9E9E9E">
                                        <iconPacks:PackIconMaterial.Style>
                                            <Style TargetType="iconPacks:PackIconMaterial">
                                                <Setter Property="Kind" Value="Eye" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowPassword}" Value="True">
                                                        <Setter Property="Kind" Value="EyeOff" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </iconPacks:PackIconMaterial.Style>
                                    </iconPacks:PackIconMaterial>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Remember Me -->
                        <CheckBox Content="Ghi nhớ đăng nhập" IsChecked="{Binding RememberMe}"
                                 Foreground="#757575" Margin="0,0,0,32" />

                        <!-- Login Button -->
                        <Button Command="{Binding LoginCommand}"
                               Style="{StaticResource PrimaryButtonStyle}"
                               Height="48" FontSize="16" FontWeight="SemiBold">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Login" Width="20" Height="20"
                                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Login.Button}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button.Content>
                        </Button>

                        <!-- Loading Indicator -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0"
                                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                            <materialDesign:PackIcon Kind="Loading" Width="20" Height="20"
                                                    Foreground="{StaticResource PrimaryBrush}"
                                                    RenderTransformOrigin="0.5,0.5">
                                <materialDesign:PackIcon.RenderTransform>
                                    <RotateTransform />
                                </materialDesign:PackIcon.RenderTransform>
                            </materialDesign:PackIcon>
                            <TextBlock Text="{loc:Tr Login.Loading}" Foreground="{StaticResource TextSecondaryBrush}"
                                      Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="© 2026 RentalSoft. Phiên bản 1.0.0"
                                  Foreground="#BDBDBD" FontSize="11" HorizontalAlignment="Center"
                                  Margin="0,32,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>


