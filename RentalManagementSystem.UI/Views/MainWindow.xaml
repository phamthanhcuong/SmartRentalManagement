<Window x:Class="RentalManagementSystem.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:views="clr-namespace:RentalManagementSystem.UI.Views"
        xmlns:vm="clr-namespace:RentalManagementSystem.UI.ViewModels"
        xmlns:loc="clr-namespace:RentalManagementSystem.UI.Localization"
        Title="{loc:Tr App.Title}"
        Width="1400" Height="860"
        MinWidth="1200" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RentalAreaViewModel}">
            <views:RentalAreaView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RoomViewModel}">
            <views:RoomView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TenantViewModel}">
            <views:TenantView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ContractViewModel}">
            <views:ContractView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VehicleLookupViewModel}">
            <views:VehicleLookupView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UtilityViewModel}">
            <views:UtilityView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ServiceViewModel}">
            <views:ServiceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InvoiceViewModel}">
            <views:InvoiceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:IncomeExpenseViewModel}">
            <views:IncomeExpenseView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AssetViewModel}">
            <views:AssetView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportViewModel}">
            <views:ReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditLogViewModel}">
            <views:AuditLogView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
                <DockPanel>
                    <!-- Logo -->
                    <Border DockPanel.Dock="Top" Height="72" Background="#4E0F25"
                           MouseLeftButtonDown="TitleBar_MouseDown">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="HomeCity" Width="32" Height="32" Foreground="White" />
                            <StackPanel>
                                <TextBlock Text="{loc:Tr S151}" FontSize="16" FontWeight="Bold"
                                          Foreground="White" />
                                <TextBlock Text="{loc:Tr App.Subtitle}" FontSize="10" Foreground="#E8B9C6" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- User Info -->
                    <Border DockPanel.Dock="Top" Padding="16,12" Background="#4E0F25" Opacity="0.7">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="18" Background="#9E2A4D">
                                <iconPacks:PackIconMaterial Kind="Account" Width="20" Height="20"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentUser.FullName}" Foreground="White"
                                          FontSize="13" FontWeight="Medium" />
                                <TextBlock Text="{Binding CurrentUser.Role, Converter={StaticResource EnumToVietnameseConverter}}" Foreground="#E8B9C6"
                                          FontSize="11" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Logout at bottom -->
                    <Border DockPanel.Dock="Bottom" Padding="8,8">
                        <Button Style="{StaticResource SidebarButtonStyle}"
                               Command="{Binding LogoutCommand}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Logout" Width="18" Height="18"
                                                           VerticalAlignment="Center"
                                                           Foreground="#EF9A9A" />
                                <TextBlock Text="{loc:Tr Menu.Logout}" VerticalAlignment="Center"
                                          Foreground="#EF9A9A" />
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Navigation Menu -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,8">
                            <TextBlock Text="{loc:Tr Menu.Group.Overview}" Foreground="#546E7A" FontSize="10"
                                      FontWeight="SemiBold" Margin="20,8,0,4" />
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="TrangChu"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=TrangChu}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Home" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.Home}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=Dashboard}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="Dashboard" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>

                            <TextBlock Text="{loc:Tr Menu.Group.Operations}" Foreground="#546E7A" FontSize="10"
                                      FontWeight="SemiBold" Margin="20,12,0,4" />
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="KhuTro"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=KhuTro}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Domain" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.Area}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="Phong"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=Phong}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="DoorOpen" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.Room}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="KhachThue"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=KhachThue}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="AccountGroup" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.Tenant}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="HopDong"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=HopDong}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="FileDocument" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.Contract}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="TraCuuXe"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=TraCuuXe}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Motorbike" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.VehicleLookup}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="DienNuoc"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=DienNuoc}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="LightningBolt" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.Utility}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="DichVu"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=DichVu}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Cog" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.Service}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="HoaDon"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=HoaDon}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Receipt" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.Invoice}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="ThuChi"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=ThuChi}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="CurrencyUsd" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.IncomeExpense}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>

                            <TextBlock Text="{loc:Tr Menu.Group.System}" Foreground="#546E7A" FontSize="10"
                                      FontWeight="SemiBold" Margin="20,12,0,4" />
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="TaiSan"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=TaiSan}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Sofa" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.Asset}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="BaoCao"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=BaoCao}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="ChartBar" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.Report}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="NhatKy"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=NhatKy}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="History" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.Audit}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                   Command="{Binding NavigateToCommand}" CommandParameter="CaiDat"
                                   Background="{Binding ActiveMenu, Converter={StaticResource MenuHighlightConverter}, ConverterParameter=CaiDat}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Cog" Width="18" Height="18" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.Settings}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="56" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Topbar -->
                <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource DividerBrush}"
                       BorderThickness="0,0,0,1"
                       MouseLeftButtonDown="TitleBar_MouseDown">
                    <Grid Margin="24,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="TrangChu"
                                    Style="{StaticResource SecondaryButtonStyle}" Padding="12,7" Margin="0,0,10,0" ToolTip="{loc:Tr S152}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Home" Width="15" Height="15" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Menu.Home}" VerticalAlignment="Center" Margin="6,0,0,0" />
                                </StackPanel>
                            </Button>
                            <TextBlock Text="{Binding CurrentPageTitle}" VerticalAlignment="Center"
                                      FontSize="18" FontWeight="SemiBold"
                                      Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                   VerticalAlignment="Center">
                            <Button Command="{Binding ToggleElderModeCommand}" Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="12,7" Margin="0,0,12,0" ToolTip="{loc:Tr S153}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="MagnifyPlus" Width="15" Height="15" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ElderModeLabel}" VerticalAlignment="Center" Margin="6,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Width="32" Height="32" Click="MinimizeButton_Click"
                                   Style="{StaticResource SecondaryButtonStyle}" Padding="0"
                                   ToolTip="{loc:Tr S154}">
                                <iconPacks:PackIconMaterial Kind="Minus" Width="14" Height="14" />
                            </Button>
                            <Button Width="32" Height="32" Click="MaximizeButton_Click"
                                   Style="{StaticResource SecondaryButtonStyle}" Padding="0"
                                   ToolTip="{loc:Tr S155}">
                                <iconPacks:PackIconMaterial Kind="WindowMaximize" Width="14" Height="14" />
                            </Button>
                            <Button Width="32" Height="32" Click="CloseButton_Click"
                                   Style="{StaticResource DangerButtonStyle}" Padding="0"
                                   ToolTip="{loc:Tr S060}">
                                <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page Content -->
                <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}">
                    <ContentControl Content="{Binding CurrentViewModel}">
                        <ContentControl.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding IsElderMode, Converter={StaticResource BoolToScaleConverter}}"
                                            ScaleY="{Binding IsElderMode, Converter={StaticResource BoolToScaleConverter}}" />
                        </ContentControl.LayoutTransform>
                    </ContentControl>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>


