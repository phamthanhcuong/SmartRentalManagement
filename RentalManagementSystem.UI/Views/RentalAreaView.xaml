<UserControl x:Class="RentalManagementSystem.UI.Views.RentalAreaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:loc="clr-namespace:RentalManagementSystem.UI.Localization">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{loc:Tr S156}" Style="{StaticResource PageTitleStyle}" VerticalAlignment="Center" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Command="{Binding OpenAddDialogCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="14,9" FontSize="14">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="Plus" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="{loc:Tr S002}" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
                <Button Command="{Binding OpenEditDialogCommand}" CommandParameter="{Binding SelectedArea}" IsEnabled="{Binding SelectedArea, Converter={StaticResource NotNullToBoolConverter}}" Style="{StaticResource SecondaryButtonStyle}" Padding="14,9" FontSize="14" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="Pencil" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="{loc:Tr S003}" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
                <Button Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedArea}" IsEnabled="{Binding SelectedArea, Converter={StaticResource NotNullToBoolConverter}}" Style="{StaticResource DangerButtonStyle}" Padding="14,9" FontSize="14" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="Delete" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="{loc:Tr S004}" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <DataGrid Style="{StaticResource ModernDataGridStyle}" ItemsSource="{Binding Areas}" SelectedItem="{Binding SelectedArea}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:Tr S157}" Binding="{Binding AreaCode}" Width="100" />
                    <DataGridTextColumn Header="{loc:Tr S158}" Binding="{Binding AreaName}" Width="*" />
                    <DataGridTextColumn Header="{loc:Tr S159}" Binding="{Binding Address}" Width="250" />
                    <DataGridTextColumn Header="{loc:Tr S160}" Binding="{Binding OwnerName}" Width="150" />
                    <DataGridTextColumn Header="{loc:Tr S161}" Binding="{Binding OwnerPhone}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Dialog -->
        <Grid Grid.RowSpan="2" Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#80000000" />
            <Border MaxWidth="480" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{loc:Tr S162}" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,20" />
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="{loc:Tr S163}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding FormAreaCode, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="{loc:Tr S164}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding FormAreaName, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,12">
                            <TextBlock Text="{loc:Tr S159}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding FormAddress, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="{loc:Tr S165}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding FormOwnerName, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="{loc:Tr S166}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding FormOwnerPhone, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="{loc:Tr S015}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseDialogCommand}" Padding="24,10" />
                        <Button Content="{loc:Tr S016}" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}" Padding="24,10" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

