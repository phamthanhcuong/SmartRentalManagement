<UserControl x:Class="RentalManagementSystem.UI.Views.RoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:loc="clr-namespace:RentalManagementSystem.UI.Localization"
             xmlns:converters="clr-namespace:RentalManagementSystem.UI.Converters">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{loc:Tr S177}" Style="{StaticResource PageTitleStyle}" />
        </Grid>

        <!-- Thanh công cụ: tìm kiếm + thao tác trên dòng đang chọn -->
        <DockPanel Grid.Row="1" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Command="{Binding OpenAddDialogCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="14,9" FontSize="14">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Plus" Width="15" Height="15" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Tr S002}" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenEditDialogCommand}" CommandParameter="{Binding SelectedRoom}"
                        IsEnabled="{Binding SelectedRoom, Converter={StaticResource NotNullToBoolConverter}}"
                        Style="{StaticResource SecondaryButtonStyle}" Padding="14,9" FontSize="14" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Pencil" Width="15" Height="15" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Tr S003}" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedRoom}"
                        IsEnabled="{Binding SelectedRoom, Converter={StaticResource NotNullToBoolConverter}}"
                        Style="{StaticResource DangerButtonStyle}" Padding="14,9" FontSize="14" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Delete" Width="15" Height="15" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Tr S004}" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <TextBox Style="{StaticResource SearchBoxStyle}" Width="360" HorizontalAlignment="Left"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    materialDesign:HintAssist.Hint="{loc:Tr S178}" />
        </DockPanel>

        <!-- Content -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <!-- Loading -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="Loading" Width="40" Height="40"
                                            Foreground="{StaticResource PrimaryBrush}"
                                            HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BusyMessage}" Foreground="{StaticResource TextSecondaryBrush}"
                              Margin="0,8,0,0" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid Style="{StaticResource ModernDataGridStyle}"
                         ItemsSource="{Binding Rooms}"
                         SelectedItem="{Binding SelectedRoom}"
                         Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{loc:Tr S179}" Binding="{Binding RoomCode}" Width="100" />
                        <DataGridTextColumn Header="{loc:Tr S180}" Binding="{Binding RoomName}" Width="*" />
                        <DataGridTextColumn Header="{loc:Tr S181}" Binding="{Binding RentalArea.AreaName}" Width="150" />
                        <DataGridTextColumn Header="{loc:Tr S182}" Binding="{Binding Area, StringFormat={}{0:N1}}" Width="110" />
                        <DataGridTextColumn Header="{loc:Tr S183}" Binding="{Binding Price, StringFormat={}{0:N0} ₫}" Width="130" />
                        <DataGridTextColumn Header="{loc:Tr S184}" Binding="{Binding Deposit, StringFormat={}{0:N0} ₫}" Width="130" />
                        <DataGridTemplateColumn Header="{loc:Tr S185}" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Available">
                                                        <Setter Property="Background" Value="#E8F5E9" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Occupied">
                                                        <Setter Property="Background" Value="#F7E9EE" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Maintenance">
                                                        <Setter Property="Background" Value="#FFF8E1" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="12" />
                                                    <Setter Property="FontWeight" Value="Medium" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Available">
                                                            <Setter Property="Text" Value="Trống" />
                                                            <Setter Property="Foreground" Value="#2E7D32" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Occupied">
                                                            <Setter Property="Text" Value="Đang thuê" />
                                                            <Setter Property="Foreground" Value="#7A1E3A" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Maintenance">
                                                            <Setter Property="Text" Value="Bảo trì" />
                                                            <Setter Property="Foreground" Value="#E65100" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Add/Edit Dialog -->
        <Grid Grid.RowSpan="3"
             Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#80000000" />
            <Border MaxWidth="520" MaxHeight="640" VerticalAlignment="Center" HorizontalAlignment="Center"
                   Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,24">
                        <TextBlock.Text>
                            <Binding Path="IsEditing" Converter="{StaticResource BoolToStringConverter}"
                                    ConverterParameter="Chỉnh sửa phòng|Thêm phòng mới" />
                        </TextBlock.Text>
                    </TextBlock>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Mã phòng -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="{loc:Tr S186}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding FormRoomCode, UpdateSourceTrigger=PropertyChanged}"
                                    materialDesign:HintAssist.Hint="VD: P101"
                                    Height="40" Padding="12,0" BorderThickness="1"
                                    BorderBrush="{StaticResource DividerBrush}" />
                        </StackPanel>

                        <!-- Tên phòng -->
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,16">
                            <TextBlock Text="{loc:Tr S187}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding FormRoomName, UpdateSourceTrigger=PropertyChanged}"
                                    materialDesign:HintAssist.Hint="{loc:Tr S188}"
                                    Height="40" Padding="12,0" BorderThickness="1"
                                    BorderBrush="{StaticResource DividerBrush}" />
                        </StackPanel>

                        <!-- Khu trọ -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,16">
                            <TextBlock Text="{loc:Tr S189}" Style="{StaticResource FormLabelStyle}" />
                            <ComboBox ItemsSource="{Binding Areas}"
                                     SelectedValuePath="Id"
                                     SelectedValue="{Binding FormAreaId}"
                                     DisplayMemberPath="AreaName"
                                     Height="40" />
                        </StackPanel>

                        <!-- Diện tích + Giá -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="{loc:Tr S190}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding FormArea, UpdateSourceTrigger=PropertyChanged}"
                                    Height="40" Padding="12,0" BorderThickness="1"
                                    BorderBrush="{StaticResource DividerBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,16">
                            <TextBlock Text="{loc:Tr S191}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding FormPrice, UpdateSourceTrigger=PropertyChanged}"
                                    Height="40" Padding="12,0" BorderThickness="1"
                                    BorderBrush="{StaticResource DividerBrush}" />
                        </StackPanel>

                        <!-- Đặt cọc + Người ở tối đa -->
                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="{loc:Tr S049}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding FormDeposit, UpdateSourceTrigger=PropertyChanged}"
                                    Height="40" Padding="12,0" BorderThickness="1"
                                    BorderBrush="{StaticResource DividerBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,16">
                            <TextBlock Text="{loc:Tr S192}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding FormMaxOccupants, UpdateSourceTrigger=PropertyChanged}"
                                    Height="40" Padding="12,0" BorderThickness="1"
                                    BorderBrush="{StaticResource DividerBrush}" />
                        </StackPanel>

                        <!-- Ghi chú -->
                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,0">
                            <TextBlock Text="{loc:Tr S120}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                    Height="80" Padding="12,8" BorderThickness="1" AcceptsReturn="True"
                                    BorderBrush="{StaticResource DividerBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                              Margin="0,12,0,0"
                              Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                               Margin="0,20,0,0">
                        <Button Content="{loc:Tr S015}" Style="{StaticResource SecondaryButtonStyle}"
                               Command="{Binding CloseDialogCommand}" Padding="24,10" />
                        <Button Content="{loc:Tr S016}" Style="{StaticResource PrimaryButtonStyle}"
                               Command="{Binding SaveCommand}" Padding="24,10" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

