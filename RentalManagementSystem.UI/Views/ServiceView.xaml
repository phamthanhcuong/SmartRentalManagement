<UserControl x:Class="RentalManagementSystem.UI.Views.ServiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Quản Lý Dịch Vụ" Style="{StaticResource PageTitleStyle}" VerticalAlignment="Center" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Command="{Binding OpenAddDialogCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="14,9" FontSize="14">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="Plus" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="Thêm" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
                <Button Command="{Binding OpenEditDialogCommand}" CommandParameter="{Binding SelectedService}" IsEnabled="{Binding SelectedService, Converter={StaticResource NotNullToBoolConverter}}" Style="{StaticResource SecondaryButtonStyle}" Padding="14,9" FontSize="14" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="Pencil" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="Sửa" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
                <Button Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedService}" IsEnabled="{Binding SelectedService, Converter={StaticResource NotNullToBoolConverter}}" Style="{StaticResource DangerButtonStyle}" Padding="14,9" FontSize="14" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="Delete" Width="15" Height="15" VerticalAlignment="Center" /><TextBlock Text="Xóa" VerticalAlignment="Center" Margin="6,0,0,0" /></StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <DataGrid Style="{StaticResource ModernDataGridStyle}" ItemsSource="{Binding Services}" SelectedItem="{Binding SelectedService}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên dịch vụ" Binding="{Binding ServiceName}" Width="*" />
                    <DataGridTextColumn Header="Loại" Binding="{Binding ServiceType, Converter={StaticResource EnumToVietnameseConverter}}" Width="120" />
                    <DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, StringFormat={}{0:N0} ₫}" Width="130" />
                    <DataGridTextColumn Header="Đơn vị" Binding="{Binding Unit}" Width="100" />
                    <DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.RowSpan="2" Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#80000000" />
            <Border MaxWidth="420" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Thông tin dịch vụ" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,20" />
                    <TextBlock Text="Tên dịch vụ *" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" Margin="0,0,0,12" />
                    <TextBlock Text="Đơn giá (₫) *" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding FormPrice, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" Margin="0,0,0,12" />
                    <TextBlock Text="Đơn vị tính" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding FormUnit, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" Margin="0,0,0,12" />
                    <TextBlock Text="Mô tả" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}" Height="60" Padding="12,8" BorderThickness="1" AcceptsReturn="True" BorderBrush="{StaticResource DividerBrush}" Margin="0,0,0,16" />
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Hủy" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseDialogCommand}" Padding="24,10" />
                        <Button Content="Lưu" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}" Padding="24,10" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

