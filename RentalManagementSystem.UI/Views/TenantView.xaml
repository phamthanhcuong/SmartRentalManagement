<UserControl x:Class="RentalManagementSystem.UI.Views.TenantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:loc="clr-namespace:RentalManagementSystem.UI.Localization">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{loc:Tr S222}" Style="{StaticResource PageTitleStyle}" />
        </Grid>

        <DockPanel Grid.Row="1" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Command="{Binding OpenAddDialogCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="14,9" FontSize="14">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Plus" Width="15" Height="15" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Tr S002}" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenEditDialogCommand}" CommandParameter="{Binding SelectedTenant}"
                        IsEnabled="{Binding SelectedTenant, Converter={StaticResource NotNullToBoolConverter}}"
                        Style="{StaticResource SecondaryButtonStyle}" Padding="14,9" FontSize="14" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Pencil" Width="15" Height="15" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Tr S003}" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenVehicleDialogCommand}" CommandParameter="{Binding SelectedTenant}"
                        IsEnabled="{Binding SelectedTenant, Converter={StaticResource NotNullToBoolConverter}}"
                        Style="{StaticResource SuccessButtonStyle}" Padding="14,9" FontSize="14" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Motorbike" Width="15" Height="15" VerticalAlignment="Center" />
                        <TextBlock Text="Xe" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedTenant}"
                        IsEnabled="{Binding SelectedTenant, Converter={StaticResource NotNullToBoolConverter}}"
                        Style="{StaticResource DangerButtonStyle}" Padding="14,9" FontSize="14" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Delete" Width="15" Height="15" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Tr S004}" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <TextBox Style="{StaticResource SearchBoxStyle}" Width="360" HorizontalAlignment="Left"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    materialDesign:HintAssist.Hint="{loc:Tr S223}" />
        </DockPanel>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <DataGrid Style="{StaticResource ModernDataGridStyle}" ItemsSource="{Binding Tenants}"
                     SelectedItem="{Binding SelectedTenant}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="{loc:Tr S224}" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="36" Height="36" CornerRadius="18" Background="#F7E9EE"
                                       HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Account" Width="20" Height="20"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{loc:Tr S225}" Binding="{Binding FullName}" Width="*" />
                    <DataGridTextColumn Header="{loc:Tr S226}" Binding="{Binding Phone}" Width="130" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="170" />
                    <DataGridTextColumn Header="CCCD/CMND" Binding="{Binding CCCD}" Width="130" />
                    <DataGridTextColumn Header="{loc:Tr S159}" Binding="{Binding Address}" Width="200" />
                    <DataGridTextColumn Header="{loc:Tr S227}" Binding="{Binding Occupation}" Width="130" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Dialog -->
        <Grid Grid.RowSpan="3" Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#80000000" />
            <Border MaxWidth="560" MaxHeight="700" VerticalAlignment="Center" HorizontalAlignment="Center"
                   Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr S228}" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,24" />

                        <!-- Avatar Upload -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Border Width="80" Height="80" CornerRadius="40" Background="#F7E9EE" HorizontalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="AccountCircle" Width="60" Height="60"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Button Content="{loc:Tr S229}" Style="{StaticResource SecondaryButtonStyle}"
                                   Command="{Binding UploadAvatarCommand}" Margin="0,8,0,0" Padding="16,6" HorizontalAlignment="Center" />
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S230}" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding FormFullName, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S231}" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding FormPhone, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="Email" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding FormEmail, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                                <TextBlock Text="CCCD/CMND" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding FormCCCD, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S232}" Style="{StaticResource FormLabelStyle}" />
                                <DatePicker SelectedDate="{Binding FormDateOfBirth}" Height="40" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S227}" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding FormOccupation, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr S233}" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding FormAddress, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,0" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                                  Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Content="{loc:Tr S015}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseDialogCommand}" Padding="24,10" />
                            <Button Content="{loc:Tr S016}" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}" Padding="24,10" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Dialog Quản lý xe -->
        <Grid Grid.RowSpan="3" Visibility="{Binding IsVehicleDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#80000000" />
            <Border MaxWidth="640" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{loc:Tr S234}" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,2" />
                    <TextBlock Text="{Binding VehicleTenant.FullName, StringFormat=Khách thuê: {0}}" Foreground="#757575" FontSize="12" Margin="0,0,0,14" />

                    <!-- Form thêm xe -->
                    <Border Background="#F5F7FA" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Tr S235}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding VehLicensePlate}" Height="38" Padding="8,0" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{loc:Tr S236}" Style="{StaticResource FormLabelStyle}" />
                            <ComboBox Grid.Row="1" Grid.Column="2" ItemsSource="{Binding VehicleTypes}" SelectedItem="{Binding VehType}" Height="38" />

                            <TextBlock Grid.Row="0" Grid.Column="4" Text="{loc:Tr S237}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding VehBrand}" Height="38" Padding="8,0" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />

                            <TextBlock Grid.Row="0" Grid.Column="6" Text="{loc:Tr S238}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Grid.Row="1" Grid.Column="6" Text="{Binding VehColor}" Height="38" Padding="8,0" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="{StaticResource DividerBrush}" />

                            <Button Grid.Row="1" Grid.Column="8" Content="{loc:Tr S002}" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding AddVehicleCommand}" Padding="18,8" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <DataGrid Style="{StaticResource ModernDataGridStyle}" ItemsSource="{Binding Vehicles}" MaxHeight="240"
                              AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{loc:Tr S239}" Binding="{Binding LicensePlate}" Width="140" />
                            <DataGridTextColumn Header="{loc:Tr S119}" Binding="{Binding VehicleType, Converter={StaticResource EnumToVietnameseConverter}}" Width="110" />
                            <DataGridTextColumn Header="{loc:Tr S240}" Binding="{Binding Brand}" Width="*" />
                            <DataGridTextColumn Header="{loc:Tr S238}" Binding="{Binding Color}" Width="90" />
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource DangerButtonStyle}" Padding="8,6"
                                                Command="{Binding DataContext.RemoveVehicleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <iconPacks:PackIconMaterial Kind="Delete" Width="13" Height="13" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                              Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="{loc:Tr S060}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseVehicleDialogCommand}" Padding="24,10" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

