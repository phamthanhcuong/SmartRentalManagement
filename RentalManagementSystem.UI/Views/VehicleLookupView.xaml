<UserControl x:Class="RentalManagementSystem.UI.Views.VehicleLookupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Tra Cứu Xe" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="Nhập biển số, tên chủ xe hoặc số điện thoại để tra cứu nhanh thông tin phương tiện ra/vào."
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Search Card -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <Border Grid.Column="0" CornerRadius="10" BorderThickness="1.5"
                        BorderBrush="{StaticResource PrimaryBrush}" Background="#FCFAFB" Height="52">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <iconPacks:PackIconMaterial Grid.Column="0" Kind="Magnify" Width="22" Height="22"
                                                    Foreground="{StaticResource PrimaryBrush}"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent" FontSize="16"
                                 VerticalContentAlignment="Center" Padding="0,0,12,0"
                                 materialDesign:HintAssist.Hint="Nhập biển số / tên chủ xe / SĐT..." />
                    </Grid>
                </Border>

                <!-- Result count -->
                <Border Grid.Column="1" CornerRadius="10" Background="#F7E9EE" Padding="18,0" Margin="14,0,0,0"
                        VerticalAlignment="Stretch" Height="52">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Motorbike" Width="20" Height="20"
                                                    Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" />
                        <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{StaticResource PrimaryDarkBrush}">
                            <Run Text="{Binding ResultCount}" FontWeight="Bold" FontSize="18" /><Run Text=" xe" FontSize="13" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Results -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <DataGrid Style="{StaticResource ModernDataGridStyle}" ItemsSource="{Binding Results}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <!-- Biển số nổi bật -->
                        <DataGridTemplateColumn Header="Biển số" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Background="{StaticResource PrimaryDarkBrush}"
                                            Padding="10,5" HorizontalAlignment="Left" Margin="0,2">
                                        <TextBlock Text="{Binding LicensePlate}" Foreground="White"
                                                   FontWeight="Bold" FontSize="14" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Loại xe" Binding="{Binding VehicleType, Converter={StaticResource EnumToVietnameseConverter}}" Width="110" />
                        <DataGridTextColumn Header="Hãng/Loại" Binding="{Binding Brand}" Width="130" />
                        <DataGridTextColumn Header="Màu" Binding="{Binding Color}" Width="90" />
                        <DataGridTextColumn Header="Chủ xe" Binding="{Binding OwnerName}" Width="*" />
                        <DataGridTextColumn Header="SĐT" Binding="{Binding OwnerPhone}" Width="120" />
                        <DataGridTemplateColumn Header="Phòng" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Background="#F7E9EE" Padding="10,3" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding RoomCode}" Foreground="{StaticResource PrimaryBrush}"
                                                   FontWeight="SemiBold" FontSize="12" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Khu" Binding="{Binding AreaName}" Width="150" />
                        <DataGridTextColumn Header="Ngày ĐK" Binding="{Binding RegisterDate, StringFormat=dd/MM/yyyy}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                    <iconPacks:PackIconMaterial Kind="CarSearch" Width="56" Height="56"
                                                Foreground="#E0CDD4" HorizontalAlignment="Center" />
                    <TextBlock Text="Không tìm thấy xe phù hợp" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
